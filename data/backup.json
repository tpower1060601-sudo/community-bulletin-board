    "list": [
      {
        "id": 1783318903069,
        "title": "電梯維修進度報告",
        "type": "urgent",
        "duration": 15,
        "content": "<p class=\"MsoNormal\"><span style=\"line-height: 115%; font-family: 標楷體;\"><span style=\"font-size: 1.45em;\">因為<span lang=\"EN-US\" style=\"\">2</span>號電梯井內的線路拉扯的緣故，導致許多線路及有的電梯門板損壞，維修需要時間，原定最後的材料在<span lang=\"EN-US\" style=\"\">7/15</span>日能夠準備好，目前已向電梯廠商催促，請加快速度修復。<span lang=\"EN-US\" style=\"\"><br>\n</span>另外，貨梯因為乘坐人數過多導致過載情形，已經重新定位完成使用，7/7電梯廠商已做安全性的重量調整，確保不再發生此事。<span lang=\"EN-US\" style=\"\"><br>\n</span>也請使用貨梯的業戶在搭乘時遇到過載警示時，調整乘坐人數，<b style=\"\"><u>以保證搭乘的安全。<span lang=\"EN-US\"><o:p></o:p></span></u></b></span></span></p>\n\n<p class=\"MsoNormal\" align=\"right\" style=\"text-align:right\"><span style=\"line-height: 115%; font-family: 標楷體;\"><span style=\"font-size: 1.45em;\">管委會<span lang=\"EN-US\" style=\"\">&amp;</span>管理中心 敬上</span><span lang=\"EN-US\" style=\"font-size: 14pt;\"><o:p></o:p></span></span></p>",
        "imageUrl": "",
        "alwaysValid": true,
        "startDate": "",
        "startTime": "",
        "endDate": "",
        "endTime": "",
        "date": "2026-07-07"
      },
